#!/usr/bin/env bash
# dais — control panel for the Eigen Software agent company.
# Same interface for you (the founder) and the agents. State lives in dais.db.
set -uo pipefail
# resolve through symlinks so a PATH symlink (~/.local/bin/dais -> repo/dais) finds the real code
__src="$0"
while [ -h "$__src" ]; do
  __dir="$(cd "$(dirname "$__src")" && pwd)"
  __src="$(readlink "$__src")"
  case "$__src" in /*) ;; *) __src="$__dir/$__src" ;; esac
done
DAIS_ROOT="$(cd "$(dirname "$__src")" && pwd)"
source "$DAIS_ROOT/harness/lib.sh"

usage(){ cat <<'U'
dais — your agent company control panel

  dais status                         everything at a glance (tasks + recent runs)
  dais top [secs]                     live control panel — act on tasks, fire guarded edges (default 2s refresh)
  dais project <name>                 a project's setup: cast + models, machine dispatch map, config
  dais tasks <project> [--assignee A] [--status S]
  dais task add <project> "title" [--id X] [--priority P] [--status S] [--assignee A] [--notes "..."]
  dais task set <id> [--status S] [--assignee A] [--pr URL] [--priority P] [--title T] [--notes "..."] [--touches-migrations true|false]
  dais tick [project] [--dry-run]     check the list once: run the most valuable pending task
  dais watch [seconds]                keep checking on an interval (default 900s); Ctrl-C to stop
  dais schedule install|uninstall|status   run the interval in the background (cross-platform)
  dais pause | resume                 park/un-park the loop (honored by watch + schedule)
  dais cancel <project>               stop the project's in-flight agent (marks it interrupted)
  dais start <id>                      run the role the machine dispatches for this task's state, now
  dais run <project> <agent>          run a specific agent now (headless claude)
  dais fire <task-id> <verb>          advance a task by firing a machine edge (guards: --confirm/--typed/--attest/--verify)
  dais edges <task-id>                the fireable edges from a task's current state
  dais logs <project> [N]             recent runs
  dais learn <project> "note"         record a durable decision/gotcha into the project's CONTEXT.md
  dais lint [project]                 validate a project (roles + project.yaml + required files)
  dais init [path]                    bootstrap a workspace (dais.yaml + CONTEXT.md + projects/ + board) at path or cwd
  dais migrate [--config <project>]     apply DB migrations | convert a project to frontmatter config
  dais scaffold <project> [--template coding|marketing]  bootstrap a project (agents/ + machine) from a workflow template
  dais role new <project> [--desc "..."] [--yes]  Claude designs a new role (persona + routing); you confirm
  dais version                        which build this machine runs (git tag/commit of the tool checkout)
U
}

# valid_status <project> <status> -> exit 0 if <status> is a state in the project's machine. The
# machine is the single source of truth for the status vocabulary (there is no fixed canonical set).
valid_status(){
  local mp; mp="$(machine_path "$1")"; [ -n "$mp" ] || return 1
  python3 -c "import sys;sys.path.insert(0,'$DAIS_ROOT/harness');import machine as M;m=M.load('$mp');sys.exit(0 if '$2' in m.get('states',{}) else 1)" 2>/dev/null
}
# machine_path lives in lib.sh (shared with dispatch.sh + run-agent.sh).
# status_help <project> -> the project's machine states, for error messages
status_help(){
  local mp; mp="$(machine_path "$1")"; [ -n "$mp" ] || return 0
  python3 -c "import sys;sys.path.insert(0,'$DAIS_ROOT/harness');import machine as M;print(' '.join(M.load('$mp').get('states',{})))" 2>/dev/null
}

cmd="${1:-status}"; shift 2>/dev/null || true
case "$cmd" in
  init)
    target="${1:-$PWD}"
    case "$target" in /*) ;; *) target="$PWD/$target" ;; esac      # absolutize
    mkdir -p "$target/projects"
    if [ ! -f "$target/dais.yaml" ]; then
      cat > "$target/dais.yaml" <<YAML
workspace: $(basename "$target")
agent_repos: $(dirname "$target")          # base dir for projects' relative repo: paths
# north_star: "one line on what this workspace is for"
YAML
    fi
    if [ ! -f "$target/CONTEXT.md" ]; then
      cat > "$target/CONTEXT.md" <<'MD'
# Workspace context

> Read first by the founder, every agent run, and dais. Keep it TIGHT — a dozen durable
> lines (it is injected into every agent run). Project specifics live in
> projects/<name>/CONTEXT.md.

## North star
(what this workspace is for)

## Operating rules (apply to every project)
- The founder gates everything outward: publishing, merging, deploying, spending.

## Founder decisions / gotchas
(durable decisions agents must honor)
MD
    fi
    [ -f "$target/.gitignore" ] || printf 'dais.db\n*.log\n__pycache__/\n.env\n' > "$target/.gitignore"
    grep -q '^\.env$' "$target/.gitignore" 2>/dev/null || echo '.env' >> "$target/.gitignore"
    DAIS_HOME="$target"; DB="$target/dais.db"; db_init
    echo "initialized dais workspace at $target"
    echo "  edit dais.yaml + CONTEXT.md, then: dais scaffold <project>" ;;

  migrate)
    if [ "${1:-}" = "--config" ]; then
      proj="${2:?usage: dais migrate --config <project>}"
      exec python3 "$DAIS_ROOT/harness/migrate_config.py" "$DAIS_HOME" "$proj"
    fi
    db_init; echo "migrations applied (recorded in schema_version). tip: run with 'dais watch' paused." ;;

  version|--version|-V)
    # who is running what: the tool checkout's tag/commit (+ -dirty if locally modified),
    # so two machines can compare builds at a glance. The workspace is stated too, since
    # one tool can drive many workspaces.
    # a packaged install (Homebrew/tarball) has no .git — a baked VERSION file wins; a source
    # checkout falls back to the live git describe.
    if [ -f "$DAIS_ROOT/VERSION" ]; then
      desc="$(cat "$DAIS_ROOT/VERSION")"; when=""   # packaged install: no .git of ours, so no date
    else                                            # (bare `git` would walk up to an unrelated repo)
      desc="$(git -C "$DAIS_ROOT" describe --tags --always --dirty 2>/dev/null || echo unknown)"
      when="$(git -C "$DAIS_ROOT" log -1 --format=%cd --date=short 2>/dev/null || true)"
    fi
    echo "dais $desc${when:+ ($when)}"
    echo "  tool:      $DAIS_ROOT"
    echo "  workspace: $DAIS_HOME" ;;

  status)
    # one-shot dashboard — data layer + renderer live in harness/dashboard.py,
    # shared with `dais top` (the live TUI) so the queries have a single home.
    # auto-init so a fresh workspace (new DAIS_HOME) renders an empty board, not a crash.
    [ -f "$DB" ] || db_init >/dev/null 2>&1
    python3 "$DAIS_ROOT/harness/dashboard.py" ;;

  project)
    # one project's SETUP on a page — cast (resolved model/effort), machine dispatch map,
    # config header. The files' view; tasks live in `dais status` / `dais top`.
    name="${1:-}"; [ -n "$name" ] || { echo "usage: dais project <name>"; exit 1; }
    python3 "$DAIS_ROOT/harness/dashboard.py" --project "$name" ;;

  top)
    # the multi-pane control panel: dashboard.py --tui instantiates panel.PanelApp
    secs="${1:-2}"
    case "$secs" in ''|*[!0-9.]*) echo "top: secs must be a number"; exit 1;; esac
    [ -f "$DB" ] || db_init >/dev/null 2>&1
    python3 "$DAIS_ROOT/harness/dashboard.py" --tui --interval "$secs" ;;

  backlog)
    # REMOVED: it grouped by hardcoded legacy statuses. The board derives from the machine now.
    echo "✋ 'dais backlog' was removed — the board derives from each project's machine."
    echo "   dais status              the whole board, grouped by machine phase"
    echo "   dais tasks ${1:-<project>}     one project's tasks"
    exit 1 ;;

  tasks)
    proj="${1:?usage: dais tasks <project> [--assignee A] [--status S]}"; shift 2>/dev/null || true
    where="project='$(sqlesc "$proj")'"
    while [ $# -gt 0 ]; do case "$1" in
      --assignee) where="$where AND assignee='$(sqlesc "$2")'"; shift 2;;
      --status)   where="$where AND status='$(sqlesc "$2")'"; shift 2;;
      *) shift;; esac; done
    if has_blocked_on; then
      db -separator ' | ' "SELECT t.id, t.status, t.priority, COALESCE(t.assignee,'-'),
        CASE WHEN t.blocked_on IS NOT NULL AND t.blocked_on<>'' AND EXISTS(
               SELECT 1 FROM tasks p WHERE p.id=t.blocked_on AND p.status NOT IN ('done','cancelled'))
             THEN '⛓on '||t.blocked_on||'  '||t.title ELSE t.title END
        FROM tasks t WHERE $where ORDER BY updated_at DESC;" || true
    else
      db -separator ' | ' "SELECT id, status, priority, COALESCE(assignee,'-'), title FROM tasks WHERE $where ORDER BY updated_at DESC;" || true
    fi ;;

  task)
    sub="${1:?task add|set}"; shift 2>/dev/null || true
    case "$sub" in
      add)
        proj="${1:?usage: dais task add <project> \"title\" [--id X] [--priority P] [--status S] [--assignee A] [--notes \"...\"] [--depends-on ID]}"; shift
        id=""; title=""; pri="medium"; st=""; asg=""; notes=""; dep=""
        while [ $# -gt 0 ]; do case "$1" in
          --id)         id="$2"; shift 2;;
          --priority)   pri="$2"; shift 2;;
          --status)     st="$2"; shift 2;;
          --assignee)   asg="$2"; shift 2;;
          --notes)      notes="$2"; shift 2;;
          --depends-on) dep="$2"; shift 2;;
          *) [ -z "$title" ] && title="$1"; shift;;
        esac; done
        [ -n "$title" ] || { echo "need a title"; exit 1; }
        # the ENGINE creates the task (machine.py create): entry-state resolution, state
        # validation, id allocation (auto retry / explicit --id collision error), dependency
        # checks — one authority instead of a bash re-implementation of each.
        [ -f "$DB" ] || db_init >/dev/null 2>&1
        MP="$(machine_path "$proj")"
        [ -n "$MP" ] || { echo "task add: no machine for project '$proj'"; exit 1; }
        args=(create "$DB" "$MP" "$proj" "$title" --priority "$pri" --assignee "$asg")
        [ -n "$st" ]    && args+=("$st")
        [ -n "$id" ]    && args+=(--id "$id")
        [ -n "$notes" ] && args+=(--notes "$notes")
        [ -n "$dep" ]   && args+=(--blocked-on "$dep")
        res="$(python3 "$DAIS_ROOT/harness/machine.py" "${args[@]}" 2>&1)" \
          || { echo "task add: $res"; exit 1; }
        id="${res%%|*}"; st="${res##*|}"
        link_run_task "$id" create; echo "added $id  [$st${asg:+ -> $asg}${dep:+ ⛓on $dep}]" ;;
      set)
        id="$1"; shift
        sets=""; newst=""; dep=""; depset=0
        while [ $# -gt 0 ]; do case "$1" in
          --status)     newst="$2"; sets="$sets, status='$(sqlesc "$2")'"; shift 2;;
          --assignee)   sets="$sets, assignee='$(sqlesc "$2")'"; shift 2;;
          --pr)         sets="$sets, pr_url='$(sqlesc "$2")'"; shift 2;;
          --priority)   sets="$sets, priority='$(sqlesc "$2")'"; shift 2;;
          --notes)      sets="$sets, notes='$(sqlesc "$2")'"; shift 2;;
          --title)      sets="$sets, title='$(sqlesc "$2")'"; shift 2;;
          --touches-migrations)  # release fact: does the encompassed diff touch DB migration files?
                        case "$2" in
                          true|1|yes)  sets="$sets, touches_migrations=1";;
                          false|0|no)  sets="$sets, touches_migrations=0";;
                          *) echo "task set: --touches-migrations needs true|false"; exit 1;;
                        esac; shift 2;;
          --depends-on) dep="$2"; depset=1                       # '' clears the dependency
                        sets="$sets, blocked_on=$([ -n "$2" ] && echo "'$(sqlesc "$2")'" || echo NULL)"; shift 2;;
          *) shift;; esac; done
        # Agents (DAIS_RUN_ID set by run-agent.sh) never set status — state changes fire edges.
        # Founder shells carry no run id, so founder surgery is untouched.
        if [ -n "$newst" ] && [[ "${DAIS_RUN_ID:-}" =~ ^[0-9]+$ ]]; then
          echo "task set: agents don't set --status — fire an edge instead: dais fire $id <verb>   (see: dais edges $id)"
          exit 1
        fi
        if [ "$depset" = 1 ]; then
          has_blocked_on || { echo "task set: dependencies need a schema upgrade — run 'dais migrate' first"; exit 1; }
          if [ -n "$dep" ]; then
            [ "$dep" = "$id" ] && { echo "task set: a task can't depend on itself"; exit 1; }
            [ -z "$(db "SELECT 1 FROM tasks WHERE id='$(sqlesc "$dep")';")" ] && { echo "task set: no such predecessor task: $dep"; exit 1; }
          fi
        fi
        sets="${sets#, }"
        [ -z "$sets" ] && { echo "nothing to set"; exit 1; }
        if [ -n "$newst" ]; then
          proj="$(db "SELECT project FROM tasks WHERE id='$(sqlesc "$id")';")"
          [ -n "$proj" ] || { echo "no task: $id"; exit 1; }
          valid_status "$proj" "$newst" || { echo "task set: invalid status '$newst'. valid: $(status_help "$proj")"; exit 1; }
        fi
        db "UPDATE tasks SET $sets, updated_at=datetime('now') WHERE id='$(sqlesc "$id")';" \
          && { verb=touch; [ "$newst" = doing ] && verb=claim; link_run_task "$id" "$verb"; echo "updated $id"; } ;;
      *) usage ;;
    esac ;;

  actions)
    # back-compat alias: a task's actions ARE its machine's fireable edges now.
    exec "$0" edges "$@" ;;

  handoff|approve)
    # REMOVED: both were legacy status pokes that bypassed the machine (and could strand a task
    # in a state its machine doesn't have). Every state change is a transition now.
    id="${1:-<task-id>}"
    echo "✋ 'dais $cmd' was removed — every state change fires a machine edge now."
    echo "   see what can fire:  dais edges $id"
    echo "   then fire it:       dais fire $id <verb> [--confirm | --typed $id | --attest <fact>]"
    exit 1 ;;

  run)
    exec "$DAIS_ROOT/harness/run-agent.sh" "$@" ;;

  start)
    # run the role the MACHINE dispatches for this task's current state, right now (the same
    # resolution the scheduler uses — machine.dispatch_role). A state with no dispatch role
    # explains itself by its band: a founder gate waits on you, a waiting state on a system
    # event, a terminal has nothing to run.
    id="${1:?usage: dais start <id>}"; shift 2>/dev/null || true
    force=0; [ "${1:-}" = "--force" ] && force=1
    row="$(db -separator '|' "SELECT status,project FROM tasks WHERE id='$(sqlesc "$id")';")"
    [ -n "$row" ] || { echo "no such task: $id"; exit 1; }
    st="${row%%|*}"; proj="${row##*|}"
    # honor the dependency chain — the scheduler skips dep-blocked tasks, and a manual start
    # must not silently jump the queue (that's how a review ran against a moving target once).
    dep="$(db "SELECT t.blocked_on FROM tasks t JOIN tasks p ON p.id=t.blocked_on
               WHERE t.id='$(sqlesc "$id")' AND p.status NOT IN ('done','cancelled');")"
    if [ -n "$dep" ] && [ "$force" != "1" ]; then
      echo "start: $id is ⛓ blocked on $dep (still open) — the scheduler won't run it either."
      echo "       run it anyway (against the not-yet-landed state): dais start $id --force"
      exit 1
    fi
    MP="$(machine_path "$proj")"
    info="$(DAIS_MP="$MP" DAIS_ST="$st" python3 -c "
import os, sys; sys.path.insert(0, '$DAIS_ROOT/harness'); import machine as M
m = M.load(os.environ['DAIS_MP']); st = os.environ['DAIS_ST']
print((M.dispatch_role(m, st) or '') + '|' + M.band_of(m, st))" 2>/dev/null)"
    role="${info%%|*}"; band="${info##*|}"
    if [ -z "$role" ]; then
      case "$band" in
        ARCHIVE)     echo "start: $id is '$st' — nothing to run." ;;
        "NEEDS YOU") echo "start: $id is '$st' — it waits on YOU. See what you can fire:  dais edges $id" ;;
        *)           echo "start: $id is '$st' — no agent dispatches this state (it waits on a system event). See:  dais edges $id" ;;
      esac
      exit 1
    fi
    echo "▶ starting $proj/$role for $id ($st)…"
    exec "$DAIS_ROOT/harness/run-agent.sh" "$proj" "$role" ;;

  scaffold)
    # bootstrap a project from a WORKFLOW TEMPLATE (coding | marketing | …). The template seeds the
    # agents/ personas (frontmatter config + body), project.yaml, CONTEXT.md AND the project's own
    # editable machine.json — so a scaffolded project runs on its state machine with no `machine:`
    # gate to set. No roles file: agent_setup()/cast() resolve everything from agents/<role>.md.
    name="${1:?usage: dais scaffold <project> [--template coding]}"; shift 2>/dev/null || true
    tmpl="coding"
    while [ $# -gt 0 ]; do case "$1" in --template) tmpl="$2"; shift 2;; *) shift;; esac; done
    [[ "$name" =~ ^[a-z0-9._-]+$ ]] || { echo "scaffold: name must be a slug (a-z 0-9 . _ -)"; exit 1; }
    src="$DAIS_ROOT/harness/templates/$tmpl"      # templates are TOOL CODE -> stay on DAIS_ROOT
    [ -d "$src" ] || { echo "scaffold: unknown template '$tmpl' — available: $(ls "$DAIS_ROOT/harness/templates" 2>/dev/null | tr '\n' ' ')"; exit 1; }
    mkdir -p "$DAIS_HOME/projects"
    dest="$DAIS_HOME/projects/$name"
    [ -e "$dest" ] && { echo "scaffold: projects/$name already exists"; exit 1; }
    cp -R "$src" "$dest"
    mkdir -p "$dest/logs"
    # seed the project's own machine from the template's workflow (a copy it can edit)
    mfile="$DAIS_ROOT/harness/machines/$tmpl.machine.json"
    [ -f "$mfile" ] && cp "$mfile" "$dest/machine.json"
    for f in "$dest/project.yaml" "$dest/CONTEXT.md"; do
      [ -f "$f" ] && { sed "s/__PROJECT__/$name/g" "$f" > "$f.tmp" && mv "$f.tmp" "$f"; }
    done
    echo "scaffolded projects/$name from '$tmpl' (machine.json seeded) — edit project.yaml, then: dais lint $name" ;;

  role)
    # role new <project> — Claude designs a new agent (frontmatter config + persona) for the
    # project; the founder confirms before anything is written; `dais lint` then guards the
    # config. Access + dispatch are the project's machine.json's job, not this command's — the
    # printed reminder after writing tells the founder to wire that up.
    sub="${1:?usage: dais role new <project> [--desc \"...\"] [--yes]}"; shift 2>/dev/null || true
    case "$sub" in
      new)
        proj="${1:?usage: dais role new <project> [--desc \"...\"] [--yes]}"; shift
        [ -d "$DAIS_HOME/projects/$proj" ] || { echo "role: no such project '$proj'"; exit 1; }
        desc=""; yes=0
        while [ $# -gt 0 ]; do case "$1" in
          --desc) desc="$2"; shift 2;;
          --yes|-y) yes=1; shift;;
          *) echo "role new: unknown arg '$1'"; exit 1;;
        esac; done
        [ -n "$desc" ] || { printf 'describe the role (what it does): '; read -r desc < /dev/tty 2>/dev/null || true; }
        [ -n "$desc" ] || { echo "role new: a description is required (--desc \"...\")"; exit 1; }
        PDIR="$DAIS_HOME/projects/$proj"
        # existing cast summary (name + resolved trigger/prec/playbook), one per line — the
        # agents/ directory IS the cast now, resolved the same way the scheduler resolves it.
        existing="$(python3 -c "
import os, sys
sys.path.insert(0, '$DAIS_ROOT/harness')
import router
root, proj = '$DAIS_HOME', '$proj'
adir = os.path.join(root, 'projects', proj, 'agents')
names = sorted(f[:-3] for f in os.listdir(adir) if f.endswith('.md')) if os.path.isdir(adir) else []
for n in names:
    s = router.agent_setup(root, proj, n)
    print(n, 'trigger=' + s['trigger'], 'prec=' + s['prec'], 'playbook=' + s['playbook'])
" 2>/dev/null)"
        pbs="$( { ls "$DAIS_ROOT/harness/playbooks/"*.md "$PDIR/playbooks/"*.md ; } 2>/dev/null | sed 's#.*/##; s#\.md$##' | sort -u | paste -sd, - )"
        genprompt="You are configuring ONE new agent for the dais multi-agent harness (a machine-routed board: each project's machine.json routes task states to roles; access + dispatch live there, not in this agent's config).
Role to design: $desc
Project: $proj
Existing cast (name trigger prec playbook):
$existing
Available playbooks: ${pbs:-code}
Rules:
- trigger: reactive (runs when the machine dispatches it) | every:Nh (cadence) | none.
- prec: integer; reviewers low, builders mid, planners high — fit it among the existing cast's precs.
- playbook: pick from the available list the craft that fits, or 'code' for ordinary coding work.
- model / effort: leave blank to inherit the project default; set one only to override it for this role.
- persona: a crisp system prompt — who the agent is, the ONE kind of work it does per run, that it reads its queue via 'dais tasks $proj --assignee <name>' and advances work by firing machine edges ('dais edges <task-id>' then 'dais fire <task-id> <verb>'). Do NOT repeat coordination boilerplate, the playbook, or CONTEXT — the harness injects those.
Output EXACTLY this and nothing else (header lines, then a line with three dashes, then the persona markdown):
name: <slug>
trigger: <reactive|every:Nh|none>
prec: <int>
playbook: <name>
model: <optional model id, or blank>
effort: <optional low|medium|high, or blank>
---
<persona markdown>"
        echo "▸ asking Claude to design the role…"
        if [ -n "${DAIS_ROLE_GEN:-}" ]; then proposal="$(DAIS_ROLE_DESC="$desc" $DAIS_ROLE_GEN)"
        else proposal="$(claude -p "$genprompt")"; fi
        [ -n "$proposal" ] || { echo "role new: the generator returned nothing"; exit 1; }
        # split on the FIRST colon only (so a value like 'every:24h' survives), lowercase the key, trim.
        field(){ printf '%s\n' "$proposal" | awk -v k="$1" '
          { i=index($0,":"); if(i){ key=tolower(substr($0,1,i-1));
              if(key==k){ v=substr($0,i+1); sub(/^[ \t]+/,"",v); sub(/[ \t]+$/,"",v); print v; exit } } }'; }
        name="$(field name)"; trig="$(field trigger)"; prec="$(field prec)"
        pbook="$(field playbook)"; model="$(field model)"; effort="$(field effort)"
        # frontmatter is line-based (key: value) — strip any stray spaces the model put in these
        # single-token values so a written frontmatter line can't get mangled.
        trig="${trig//[[:space:]]/}"; prec="${prec//[[:space:]]/}"; pbook="${pbook//[[:space:]]/}"
        model="${model//[[:space:]]/}"; effort="${effort//[[:space:]]/}"
        persona="$(printf '%s\n' "$proposal" | awk 'f; /^---[[:space:]]*$/{f=1}')"
        [[ "$name" =~ ^[a-z0-9._-]+$ ]] || { echo "role new: generator returned a bad/blank name: '$name'"; exit 1; }
        [ -n "$persona" ] || { echo "role new: proposal had no persona (after the --- line)"; exit 1; }
        [ -e "$PDIR/agents/$name.md" ] && { echo "role new: role '$name' already exists (agents/$name.md)"; exit 1; }
        echo; echo "Proposed role for $proj:"
        printf '  %-12s trigger=%s prec=%s playbook=%s%s%s\n' \
          "$name" "$trig" "$prec" "$pbook" "${model:+ model=$model}" "${effort:+ effort=$effort}"
        echo "  persona → agents/$name.md ($(printf '%s\n' "$persona" | grep -c '') lines)"
        if [ "$yes" -ne 1 ]; then
          printf 'create this role? [y/N] '; read -r ans < /dev/tty 2>/dev/null || ans=""
          case "$ans" in y|Y|yes|YES) ;; *) echo "cancelled — nothing written."; exit 0;; esac
        fi
        mkdir -p "$PDIR/agents"
        {
          echo "---"
          echo "trigger: $trig"
          echo "prec: $prec"
          [ -n "$pbook" ] && echo "playbook: $pbook"
          [ -n "$model" ] && echo "model: $model"
          [ -n "$effort" ] && echo "effort: $effort"
          echo "---"
          printf '%s\n' "$persona"
        } > "$PDIR/agents/$name.md"
        echo "✓ wrote agents/$name.md (frontmatter + persona) — no roles-file row. access defaults to"
        echo "  'review' until you add roles.$name.access + dispatch edges to projects/$proj/machine.json."
        echo "linting ${proj}…"
        "$DAIS_ROOT/dais" lint "$proj" ;;
      *) echo "usage: dais role new <project> [--desc \"...\"] [--yes]"; exit 1;;
    esac ;;

  learn)
    proj="${1:?usage: dais learn <project> \"durable note\"}"; shift
    note="$*"
    [ -n "$note" ] || { echo "usage: dais learn <project> \"durable note\""; exit 1; }
    f="$DAIS_HOME/projects/$proj/CONTEXT.md"
    [ -f "$f" ] || { echo "no CONTEXT.md for project '$proj'"; exit 1; }
    printf -- '- %s\n' "$note" >> "$f" && echo "noted in $proj/CONTEXT.md" ;;

  lint)
    # validate the roles config(s): one reactive role per status, valid fields, personas exist
    python3 "$DAIS_ROOT/harness/router.py" --lint "$DAIS_HOME" "${1:-}"; rc=$?
    # + coherence-lint any project machine(s) (design/machine-model.md)
    if [ -n "${1:-}" ]; then _projs=("$1"); else _projs=(); for p in "$DAIS_HOME"/projects/*/; do [ -d "$p" ] && _projs+=("$(basename "$p")"); done; fi
    for pn in "${_projs[@]+"${_projs[@]}"}"; do
      _mp="$(machine_path "$pn")"; [ -n "$_mp" ] || continue
      echo "machine[$pn]: $(basename "$_mp")"
      python3 "$DAIS_ROOT/harness/machine.py" lint "$_mp" || rc=1
    done
    exit $rc ;;

  fire)
    # machine-driven transition: fire the (state,verb) edge for a task. Actor defaults to the founder
    # (your shell) or $DAIS_ACTOR (an agent run); --by overrides. Guards: --confirm --typed X
    # --attest fact --verify check. See design/machine-model.md.
    id="${1:?usage: dais fire <task-id> <verb> [--by role] [--confirm] [--typed X] [--attest fact] [--verify check]}"
    verb="${2:?usage: dais fire <task-id> <verb> [...]}"; shift 2 2>/dev/null || true
    proj="$(db "SELECT project FROM tasks WHERE id='$(sqlesc "$id")';")"
    [ -n "$proj" ] || { echo "no task: $id"; exit 1; }
    MP="$(machine_path "$proj")"
    [ -n "$MP" ] || { echo "fire: project '$proj' has no machine (set 'machine:' in project.yaml); use 'dais task set'"; exit 1; }
    actor="${DAIS_ACTOR:-founder}"
    args=(); while [ $# -gt 0 ]; do case "$1" in --by) actor="$2"; shift 2;; *) args+=("$1"); shift;; esac; done
    exec python3 "$DAIS_ROOT/harness/machine.py" fire "$DB" "$MP" "$id" "$verb" "$actor" "${args[@]+"${args[@]}"}" ;;

  edges)
    # discovery: the fireable edges from a task's current state (for agents + the founder)
    id="${1:?usage: dais edges <task-id>}"
    row="$(db -separator '|' "SELECT project,status FROM tasks WHERE id='$(sqlesc "$id")';")"
    [ -n "$row" ] || { echo "no task: $id"; exit 1; }
    eproj="${row%%|*}"; estate="${row#*|}"
    MP="$(machine_path "$eproj")"
    [ -n "$MP" ] || { echo "edges: project '$eproj' has no machine"; exit 1; }
    echo "$id  [$estate]:"
    exec python3 "$DAIS_ROOT/harness/machine.py" edges "$MP" "$estate" ;;

  tick)
    exec "$DAIS_ROOT/harness/dispatch.sh" "$@" ;;

  watch)
    interval="${1:-900}"
    par="${2:-1}"   # parallel width: how many agents may run at once (1 = serial, the default)
    [[ "$interval" =~ ^[0-9]+$ ]] || { echo "usage: dais watch [interval-seconds] [parallel-1to5]"; exit 1; }
    [[ "$par" =~ ^[0-9]+$ ]]      || { echo "usage: dais watch [interval-seconds] [parallel-1to5]"; exit 1; }
    [ "$par" -lt 1 ] && par=1; [ "$par" -gt 5 ] && par=5
    export DAIS_MAX_PARALLEL="$par"
    # singleton + discoverable: record our pid (+interval/par) so `dais top` can show/stop us,
    # and refuse to start a second loop that would double-dispatch the same board.
    PIDF="$DAIS_HOME/projects/.watch.pid"
    if [ -f "$PIDF" ] && kill -0 "$(awk '{print $1}' "$PIDF" 2>/dev/null)" 2>/dev/null; then
      echo "watch already running (pid $(awk '{print $1}' "$PIDF")). stop it first."; exit 1
    fi
    echo "$$ $interval $par" > "$PIDF"
    trap 'rm -f "$PIDF"' EXIT
    # Clean stop: parallel agents are detached (backgrounded), so they don't receive this
    # terminal's Ctrl-C. On stop we TERM each live agent's whole tree (lib.sh kill_tree); the
    # agent's EXIT trap marks the run interrupted and its task stays put, resuming on the next start.
    stop(){
      echo; echo "■ watch stopping — halting any in-flight agents…"
      for pid in $(live_lock_pids); do kill_tree "$pid"; done
      echo "■ stopped. In-flight runs are marked interrupted; their tasks stay put and resume on the next start. Safe to restart anytime."
      rm -f "$PIDF"
      exit 0
    }
    trap stop INT TERM
    if [ "$par" -gt 1 ]; then
      echo "dais watch — up to ${par} agents in parallel (priority-ordered), polling every ${interval}s when idle. Ctrl-C to stop (safe anytime)."
    else
      echo "dais watch — one agent at a time (full live stream), polling every ${interval}s when idle. Ctrl-C to stop (safe anytime)."
    fi
    while true; do
      printf '\n[%s] ─────────────────────────────────\n' "$(date '+%H:%M:%S')"
      "$DAIS_ROOT/harness/dispatch.sh"; rc=$?
      if [ "$rc" -eq 0 ]; then sleep 10          # work in flight → drain: check back shortly
      else sleep "$interval"; fi                 # idle (10) or backed off (20) → poll on the interval
    done ;;

  pause)
    touch "$DAIS_HOME/projects/.paused" && echo "⏸ paused — the loop (watch + schedule) idles until: dais resume" ;;

  resume)
    rm -f "$DAIS_HOME/projects/.paused" && echo "▶ resumed — work resumes on the next tick" ;;

  cancel)
    proj="${1:?usage: dais cancel <project>}"
    n=0
    for pid in $(live_lock_pids "$proj"); do kill_tree "$pid"; n=$((n+1)); done
    [ "$n" -gt 0 ] && echo "■ cancelled $n in-flight agent(s) in $proj — marked interrupted; task stays put" \
                   || echo "nothing running in $proj" ;;

  schedule)
    sub="${1:-status}"; PLIST="$HOME/Library/LaunchAgents/com.dais.dispatch.plist"
    case "$sub" in
      install)
        interval="${2:-900}"
        [[ "$interval" =~ ^[0-9]+$ ]] || { echo "usage: dais schedule install [interval-seconds]"; exit 1; }
        os="${DAIS_FORCE_OS:-$(uname)}"
        case "$os" in
          Darwin)
            mkdir -p "$HOME/Library/LaunchAgents"
            cat > "$PLIST" <<PL
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.dais.dispatch</string>
  <key>ProgramArguments</key><array><string>$DAIS_ROOT/dais</string><string>tick</string></array>
  <key>StartInterval</key><integer>$interval</integer>
  <key>StandardOutPath</key><string>$DAIS_HOME/projects/.dispatch.log</string>
  <key>StandardErrorPath</key><string>$DAIS_HOME/projects/.dispatch.log</string>
  <key>RunAtLoad</key><false/>
</dict></plist>
PL
            launchctl unload "$PLIST" 2>/dev/null || true
            launchctl load "$PLIST" && echo "scheduled: a tick every ${interval}s (background, survives logout). logs -> projects/.dispatch.log"
            echo "note: needs the Mac awake + you logged in. uninstall with: dais schedule uninstall" ;;
          Linux)
            echo "Linux: add this line to your crontab (run: crontab -e):"
            echo "  */$(( interval/60 < 1 ? 1 : interval/60 )) * * * * $DAIS_ROOT/dais tick >> $DAIS_HOME/projects/.dispatch.log 2>&1"
            echo "(cron's finest granularity is 1 minute; for sub-minute polling use: dais watch $interval)" ;;
          *)
            echo "Background scheduling isn't wired for '$os'. Use the portable foreground loop instead:"
            echo "  dais watch ${interval}" ;;
        esac ;;
      uninstall)
        launchctl unload "$PLIST" 2>/dev/null || true; rm -f "$PLIST"; echo "unscheduled" ;;
      status)
        launchctl list 2>/dev/null | grep -q com.dais.dispatch && echo "scheduled (background)" || echo "not scheduled (use: dais watch, or dais schedule install)" ;;
      *) echo "usage: dais schedule install|uninstall|status" ;;
    esac ;;

  logs)
    proj="${1:-}"; n="${2:-8}"
    [[ "$n" =~ ^[0-9]+$ ]] || { echo "logs: N must be an integer"; exit 1; }
    w=""; [ -n "$proj" ] && w="WHERE project='$(sqlesc "$proj")'"
    db -separator ' | ' "SELECT started_at, project||'/'||agent, status, log_path FROM runs $w ORDER BY id DESC LIMIT $n;" || true ;;

  ""|help|-h|--help) usage ;;
  *) echo "unknown: $cmd"; usage; exit 1 ;;
esac
